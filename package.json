{
  "name": "react-native-thermal-printer",
  "version": "1.0.0",
  "description": "Full-featured ESC/POS thermal printer library for React Native. Supports Epson TM-T20X II and compatibles via USB, Serial, Bluetooth and TCP/IP.",
  "main": "lib/commonjs/index.js",
  "module": "lib/module/index.js",
  "types": "lib/typescript/index.d.ts",
  "react-native": "src/index.ts",
  "source": "src/index.ts",
  "exports": {
    ".": {
      "import": "./lib/module/index.js",
      "require": "./lib/commonjs/index.js",
      "types": "./lib/typescript/index.d.ts"
    }
  },
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "*.podspec",
    "!lib/typescript/example",
    "!android/build",
    "!ios/build",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__"
  ],
  "scripts": {
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"**/*.{js,ts,tsx}\"",
    "prepare": "bob build",
    "release": "release-it"
  },
  "keywords": [
    "react-native",
    "thermal-printer",
    "esc-pos",
    "epson",
    "tm-t20",
    "receipt-printer",
    "barcode",
    "qrcode",
    "boleto"
  ],
  "repository": "https://github.com/your-org/react-native-thermal-printer",
  "author": "",
  "license": "MIT",
  "peerDependencies": {
    "react": "*",
    "react-native": "*"
  },
  "devDependencies": {
    "@react-native/eslint-config": "^0.73.1",
    "@types/jest": "^29.5.5",
    "@types/react": "^18.2.44",
    "eslint": "^8.51.0",
    "jest": "^29.7.0",
    "react": "18.2.0",
    "react-native": "0.73.0",
    "react-native-builder-bob": "^0.23.2",
    "typescript": "^5.2.2"
  },
  "jest": {
    "preset": "react-native",
    "modulePathIgnorePatterns": ["<rootDir>/lib/"]
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      ["typescript", { "project": "tsconfig.build.json" }]
    ]
  },
  "codegenConfig": {
    "name": "RNThermalPrinterSpec",
    "type": "modules",
    "jsSrcsDir": "src"
  }
}
