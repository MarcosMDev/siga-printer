<?xml version="1.0" encoding="utf-8"?>
<!--
  USB Device Filter — Epson TM series
  Place this file at: android/app/src/main/res/xml/usb_device_filter.xml

  Reference it in AndroidManifest.xml inside the <activity> tag:

    <intent-filter>
      <action android:name="android.hardware.usb.action.USB_DEVICE_ATTACHED" />
    </intent-filter>
    <meta-data
      android:name="android.hardware.usb.action.USB_DEVICE_ATTACHED"
      android:resource="@xml/usb_device_filter" />

  This makes Android automatically prompt for USB permission when
  the printer is plugged in, without any app code needed.
-->
<resources>

  <!-- Epson TM-T20  (USB) -->
  <usb-device vendor-id="0x04B8" product-id="0x0201" />

  <!-- Epson TM-T20II (USB) -->
  <usb-device vendor-id="0x04B8" product-id="0x0202" />

  <!-- Epson TM-T20X / TM-T20X II (USB) — primary target -->
  <usb-device vendor-id="0x04B8" product-id="0x0E2A" />

  <!-- Epson TM-T88V (USB) -->
  <usb-device vendor-id="0x04B8" product-id="0x0E15" />

  <!-- Epson TM-T88VI (USB) -->
  <usb-device vendor-id="0x04B8" product-id="0x0E28" />

  <!-- Epson TM-T82 (USB) -->
  <usb-device vendor-id="0x04B8" product-id="0x0E0F" />

  <!-- Epson TM-T70II (USB) -->
  <usb-device vendor-id="0x04B8" product-id="0x0E1F" />

  <!-- Epson TM-U220 (USB) -->
  <usb-device vendor-id="0x04B8" product-id="0x0074" />

  <!-- Generic USB-Serial adapters (for RS-232 connection) -->
  <!-- Prolific PL2303 -->
  <usb-device vendor-id="0x067B" />
  <!-- FTDI FT232 -->
  <usb-device vendor-id="0x0403" />
  <!-- Silicon Labs CP210x -->
  <usb-device vendor-id="0x10C4" />
  <!-- CH340/CH341 -->
  <usb-device vendor-id="0x1A86" />

</resources>
